# Python
__pycache__/
*.py[cod]
*.egg-info/
.pytest_cache/
.ipynb_checkpoints/

# Virtual environment
.venv/
venv/

# Generated results: per-run JSON/CSV + their .meta.json sidecars are
# regenerable and stay out of git. Only committed summaries are tracked.
results/*
!results/.gitkeep
!results/*.summary.csv

# Generated figures are regenerable via `make figures`. Commit the PNGs (results
# of record; render on GitHub) and the lighter SVGs; ignore everything else and
# the one oversized vector dump (canyon_flow_HW1.svg, ~9 MB — regenerate locally).
figures/*
!figures/.gitkeep
!figures/*.png
!figures/*.svg
figures/canyon_flow_HW1.svg

# CODASC reference data is KIT's; do not redistribute. It is downloaded by the
# user (see data/validation/README.md) and stays out of git.
data/validation/*.txt
data/validation/*.xls
data/validation/*.xlsx

# OS / editor cruft
.DS_Store
._*
*.swp

# SMB/Samba delete tombstones + network-fs temp artifacts (this tree is on a share)
.smbdelete*
.fuse_hidden*

# Claude Code local tooling/session state
.claude/

# Internal working docs — NOT for public release. These contain a student's name,
# personal mentoring notes, and publication/admissions strategy. Kept local; a
# scrubbed public version must be authored deliberately before any inclusion.
HANDOFF.md
paper/student_primer.md
paper/ghtc_skeleton.md
paper/nhsjs_skeleton.md
# working bibliography with [STUDENT MUST VERIFY] flags -- not public-ready:
paper/references.md
