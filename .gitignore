# Python
__pycache__/
*.py[cod]
*.egg-info/
.pytest_cache/
.ipynb_checkpoints/

# Virtual environment
.venv/
venv/

# Generated results: per-run JSON/CSV + their .meta.json sidecars are
# regenerable and stay out of git. Only committed summaries are tracked.
results/*
!results/.gitkeep
!results/*.summary.csv

# Generated figures are regenerable via `make figures`; ignore by default.
figures/*
!figures/.gitkeep

# CODASC reference data is KIT's; do not redistribute. It is downloaded by the
# user (see data/validation/README.md) and stays out of git.
data/validation/*.txt
data/validation/*.xls
data/validation/*.xlsx

# OS / editor cruft
.DS_Store
._*
*.swp

# Claude Code local tooling/session state
.claude/
